{
  "expo": {
    "name": "dispatcher",
    "slug": "dispatcher",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#252B33"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.avitaub.dispatcher"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Dispatcher needs photo access so you can optionally add a picture of yourself and your vehicle during setup."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Dispatcher needs photo access so you can optionally add a picture of yourself and your vehicle during setup.",
          "savePhotosPermission": "Dispatcher does not save photos to your library.",
          "preventAutomaticLimitedAccessAlert": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dispatcher uses your location to match you with nearby rides while you’re using the app.",
          "locationAlwaysAndWhenInUsePermission": "Dispatcher needs Always location so we can match you with rides even when the app is in the background.",
          "locationAlwaysPermission": "Dispatcher needs Always location so we can match you with rides even when the app is in the background.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#B0C2CC",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "94f17225-3da2-4771-a86c-546b875093e2"
      }
    }
  }
}
