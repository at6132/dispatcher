# Required — Railway public API (no trailing slash)
# Used by src/api/client.ts for all /v1/* requests
EXPO_PUBLIC_API_URL=https://dispatcher-production-31d1.up.railway.app

# Web app (Expo export) is served at:
# https://web-production-e0cc9.up.railway.app

# Optional — client debug logs are already on in __DEV__;
# set this to force logs in a production/release build
# EXPO_PUBLIC_DEBUG_LOGS=1

# Optional — npm run tunnel / build:internal post links to Telegram
# (also reads server/.env). For a channel: add the bot as admin, then use the channel id (-100…).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=
# TELEGRAM_TUNNEL_CHAT_IDS=   # optional override; otherwise uses TELEGRAM_CHAT_IDS
