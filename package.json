{
  "name": "dispatcher",
  "version": "1.0.0",
  "description": "Shared drive board for drivers — post free-text routes, apply/accept, unlock contact, track 10% off-app balances. See docs/PRODUCT.md.",
  "main": "index.ts",
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-masked-view/masked-view": "0.3.2",
    "expo": "~54.0.36",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-updates": "~29.0.19",
    "lucide-react-native": "^1.24.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "tunnel": "node scripts/expo-tunnel.mjs",
    "build:internal": "node scripts/eas-internal-build.mjs",
    "update:internal": "node scripts/eas-update-internal.mjs",
    "build:testflight": "eas build --profile production --platform ios --auto-submit --non-interactive",
    "update:production": "eas update --channel production --environment production --non-interactive",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "start:web": "serve -s dist -l tcp://0.0.0.0:${PORT:-8080}"
  },
  "private": true
}
