NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://dispatcher:dispatcher@localhost:5432/dispatcher
REDIS_URL=redis://127.0.0.1:6379
JWT_ACCESS_SECRET=dev-access-secret-change-me-32chars-min
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-32chars-min
TZ=America/New_York
# Required in production. Native Expo does not need CORS; admin_app (browser) does.
# Allowlist admin console origin(s). Requests with no Origin header (mobile) still work.
CORS_ORIGINS=http://localhost:5173
# Optional S3 / Railway bucket
# S3_ENDPOINT=
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true
# Telegram error alerts (@BotFather token + chat IDs)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_IDS=123456789,987654321
# TELEGRAM_ALERT_MIN_STATUS=500
# Global slow-request Telegram threshold (ms); default 1500
# SLOW_REQUEST_MS=1500
# Admin console (password + Telegram /allow). Password min 12 chars.
# ADMIN_PASSWORD=change-me-admin-12+
# ADMIN_JWT_SECRET=change-me-to-a-long-random-secret-32chars+
# ADMIN_SESSION_TTL_SEC=3600
# ADMIN_CHALLENGE_TTL_SEC=300
# Optional PostHog mirror
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
# Capacity / k6 load tests — header X-Load-Test must match (min 32 chars).
# Skips IP rate limits only; remove after the test window.
# LOAD_TEST_BYPASS_SECRET=change-me-load-test-secret-32chars-min
